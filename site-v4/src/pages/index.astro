  <!-- PDF.js CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
  
  <script>
    // Initialize PDF.js worker
    window.pdfjsLib = window['pdfjs-dist/build/pdf'];
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    // Lightbox logic
    const lightboxModal = document.getElementById('lightbox-modal');
    const lightboxCanvas = document.getElementById('lightbox-canvas');
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxLoading = document.getElementById('lightbox-loading');
    
    window.openLightbox = async function(pdfUrl, title) {
      if (!lightboxModal) return;
      lightboxModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      if (lightboxTitle) lightboxTitle.textContent = title;
      if (lightboxLoading) lightboxLoading.style.display = 'flex';
      
      const ctx = lightboxCanvas.getContext('2d');
      ctx.clearRect(0, 0, lightboxCanvas.width, lightboxCanvas.height);
      
      try {
        const loadingTask = pdfjsLib.getDocument(pdfUrl);
        const pdf = await loadingTask.promise;
        const page = await pdf.getPage(1);
        
        // Render at high resolution for lightbox
        const viewport = page.getViewport({ scale: 2.5 });
        lightboxCanvas.width = viewport.width;
        lightboxCanvas.height = viewport.height;
        
        await page.render({
          canvasContext: ctx,
          viewport: viewport
        }).promise;
        
      } catch (err) {
        console.error('Error rendering high-res PDF:', err);
      } finally {
        if (lightboxLoading) lightboxLoading.style.display = 'none';
      }
    };

    window.closeLightbox = function() {
      if (lightboxModal) {
        lightboxModal.classList.add('hidden');
        document.body.style.overflow = '';
      }
    };

    // Lazy load PDF thumbnails using IntersectionObserver
    document.addEventListener('DOMContentLoaded', () => {
      const pdfContainers = document.querySelectorAll('.pdf-preview-container');
      
      const renderThumbnail = async (container) => {
        if (container.dataset.rendered === 'true') return;
        container.dataset.rendered = 'true';
        
        const pdfUrl = container.dataset.pdf;
        const canvas = container.querySelector('.pdf-canvas');
        const loading = container.querySelector('.pdf-loading');
        
        if (!canvas || !pdfUrl) return;
        
        try {
          const loadingTask = pdfjsLib.getDocument(pdfUrl);
          const pdf = await loadingTask.promise;
          const page = await pdf.getPage(1);
          
          // Render at lower resolution for thumbnails
          const viewport = page.getViewport({ scale: 1.0 });
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          
          const ctx = canvas.getContext('2d');
          await page.render({
            canvasContext: ctx,
            viewport: viewport
          }).promise;
          
          canvas.classList.remove('opacity-0');
          if (loading) loading.style.display = 'none';
        } catch (err) {
          console.error('Error rendering thumbnail:', pdfUrl, err);
        }
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            renderThumbnail(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: '200px' }); // start loading slightly before they appear

      pdfContainers.forEach(container => observer.observe(container));
    });

    // Toggle Modal function
    window.toggleModal = function() {
      const modal = document.getElementById('privacy-modal');
      if (modal) {
        const isHidden = modal.classList.contains('hidden');
        if (isHidden) {
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden'; // Lock scroll
        } else {
          modal.classList.add('hidden');
          document.body.style.overflow = ''; // Unlock scroll
        }
      }
    };

    // Speed Dial toggle logic
    const speedDialBtn = document.getElementById('speed-dial-btn');
    const speedDialItems = document.querySelectorAll('.speed-dial-item');
    const iconDefault = document.getElementById('speed-dial-icon-default');
    const iconClose = document.getElementById('speed-dial-icon-close');
    let isSpeedDialOpen = false;

    if (speedDialBtn) {
      speedDialBtn.addEventListener('click', () => {
        isSpeedDialOpen = !isSpeedDialOpen;
        
        if (isSpeedDialOpen) {
          iconDefault?.classList.add('scale-0', 'opacity-0', '-rotate-90');
          iconClose?.classList.remove('scale-0', 'opacity-0', 'rotate-90');
          
          speedDialItems.forEach(item => {
            item.classList.remove('opacity-0', 'scale-50', 'pointer-events-none');
            item.classList.add('opacity-100', 'scale-100', 'pointer-events-auto', 'relative', 'bottom-0');
            item.classList.remove('absolute');
          });
        } else {
          iconDefault?.classList.remove('scale-0', 'opacity-0', '-rotate-90');
          iconClose?.classList.add('scale-0', 'opacity-0', 'rotate-90');
          
          speedDialItems.forEach(item => {
            item.classList.add('opacity-0', 'scale-50', 'pointer-events-none', 'absolute');
            item.classList.remove('opacity-100', 'scale-100', 'pointer-events-auto', 'relative', 'bottom-0');
          });
        }
      });
    }

    // Phone mask and form handling logic
    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    if (phoneInput) {
      phoneInput.addEventListener('input', function (e) {
        let x = e.target.value.replace(/\D/g, '').match(/(\d{0,1})(\d{0,3})(\d{0,3})(\d{0,2})(\d{0,2})/);
        if (!x[2]) { e.target.value = '+7'; return; }
        e.target.value = '+7 (' + x[2] + (x[3] ? ') ' + x[3] : '') + (x[4] ? '-' + x[4] : '') + (x[5] ? '-' + x[5] : '');
      });
    }

    const form = document.getElementById('booking-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Check honeypot
        const botField = (document.getElementById('bot_field') as HTMLInputElement)?.value;
        if (botField) {
          form.classList.add('hidden');
          if (successMsg) successMsg.classList.remove('hidden');
          return;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        // TODO: Update URL when Cloud Function is ready
        const API_URL = '/api/submit'; 
        
        try {
          // Temporarily mock success until backend is ready
          form.classList.add('hidden');
          if (successMsg) successMsg.classList.remove('hidden');
        } catch (error) {
          console.error(error);
          alert('Произошла ошибка при отправке заявки. Пожалуйста, напишите в WhatsApp.');
        }
      });
    }
  </script>
