---
import Layout from '../layouts/Layout.astro';
import content from '../data/content.json';
import docsInfo from '../data/documents.json';
---

<Layout
  title='Семейный центр остеопатии "Астраханский остеопатический центр Севрюкова"'
  description="Семейный остеопатический центр в Астрахани. Остеопатия для детей, беременных и взрослых. Мягкие техники без лекарств."
>

  <!-- Speed Dial -->
  <div id="speed-dial-container" class="speed-dial-container">
    <button id="speed-dial-btn" class="speed-dial-btn" aria-label="Связаться">
      <svg id="speed-dial-icon-default" class="speed-dial-icon" width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
      <svg id="speed-dial-icon-close" class="speed-dial-icon hidden-icon" width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <a href={content.contacts.whatsapp} target="_blank" rel="noopener noreferrer" class="speed-dial-item whatsapp" aria-label="WhatsApp">
      <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M20.52 3.449A11.94 11.94 0 0 0 12 0a11.96 11.96 0 0 0-11.95 12c0 1.91.5 3.78 1.45 5.43L0 24l6.72-1.75a11.95 11.95 0 0 0 5.28 1.23h.01a11.95 11.95 0 0 0 11.96-12 11.9 11.9 0 0 0-3.45-8.03ZM12 21.48a9.9 9.9 0 0 1-5.06-1.37l-.36-.21-3.76.99 1-3.66-.23-.37A9.94 9.94 0 0 1 2.05 12a9.96 9.96 0 0 1 9.95-10 9.9 9.9 0 0 1 7.04 2.92A9.9 9.9 0 0 1 21.95 12a9.95 9.95 0 0 1-9.95 9.48Zm5.46-7.44c-.3-.15-1.78-.88-2.05-.98-.28-.1-.48-.15-.68.15-.2.3-.77.98-.95 1.18-.17.2-.35.23-.65.08-.3-.15-1.27-.47-2.42-1.32-.89-.66-1.5-1.48-1.67-1.78-.18-.3 0-.46.15-.61.13-.14.3-.35.45-.53.15-.18.2-.3.3-.5.1-.2.05-.38-.03-.53-.08-.15-.68-1.64-.93-2.25-.24-.6-.48-.52-.68-.53-.18-.01-.38-.01-.58-.01-.2 0-.53.08-.8.38-.28.3-1.05 1.03-1.05 2.5 0 1.48 1.08 2.9 1.23 3.1.15.2 2.12 3.23 5.14 4.53.72.3 1.28.48 1.72.62.72.23 1.38.2 1.9.12.58-.09 1.78-.73 2.03-1.43.25-.7.25-1.3.18-1.43-.08-.13-.28-.2-.58-.35Z"/></svg>
    </a>
    <a href={content.contacts.telegram} target="_blank" rel="noopener noreferrer" class="speed-dial-item telegram" aria-label="Telegram">
      <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.123-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    </a>
    <a href={content.contacts.max} target="_blank" rel="noopener noreferrer" class="speed-dial-item max" aria-label="Max">
      <img src="https://maxicons.ru/icons/MAX.svg" alt="MAX" width="32" height="32" />
    </a>
  </div>

  <!-- Header -->
  <header class="header">
    <div class="container header-inner">
      <div class="logo">
        <span>✦</span> {content.clinic.name}
        <span class="logo-sub">{content.clinic.subtitle}</span>
      </div>
      <nav class="nav">
        <a href="#services">Услуги</a>
        <a href="#about">О центре</a>
        <a href="#doctors">Врачи</a>
        <a href="#reviews">Отзывы</a>
        <a href="#documents">Документы</a>
        <a href="#contact">Контакты</a>
      </nav>
      <a href={`tel:${content.contacts.phoneTel}`} class="header-phone">{content.contacts.phone}</a>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <h1 class="hero-title">
          {content.hero.titleLine1} <i>{content.hero.titleEmphasis}</i> {content.hero.titleLine2}<br>
          <span class="hero-subtitle">{content.hero.subtitle}</span>
        </h1>
        <p class="hero-text">{content.hero.description}</p>
        <a href="#contact" class="btn-primary">{content.hero.cta}</a>
        <div class="hero-stats">
          {content.hero.stats.map(stat => (
            <div class="stat-item">
              <span class="stat-number">{stat.number}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-image"></div>
    </div>
  </section>

  <!-- Directions -->
  <section class="section" id="services">
    <div class="container">
      <h2 class="section-title">Направления остеопатии</h2>
      <p class="section-subtitle">Индивидуальный подход к каждому пациенту. Работаем с причинами, а не со следствиями.</p>
      <div class="services-grid">
        {content.directions.map(direction => (
          <div class="service-card">
            <div class="service-icon">{direction.icon}</div>
            <h3>{direction.title}</h3>
            <ul>
              {direction.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section section-alt" id="pricing">
    <div class="container">
      <h2 class="section-title">Услуги и цены</h2>
      <p class="section-subtitle">Прозрачная стоимость приёма. Работаем без предоплаты.</p>
      <div class="pricing-grid">
        {content.services.map(service => (
          <div class={`price-card${service.featured ? ' featured' : ''}`}>
            {service.featured && <span class="price-badge">Частый выбор</span>}
            <h3>{service.name}</h3>
            {service.audience && <span class="price-audience">{service.audience}</span>}
            <div class="price-amount">{service.price}</div>
            {service.duration && <div class="price-duration">Длительность: {service.duration}</div>}
            <button
              type="button"
              class="price-btn"
              onclick={`document.getElementById('service').value = '${service.name}'; document.getElementById('contact').scrollIntoView({behavior: 'smooth'});`}
            >
              Записаться
            </button>
          </div>
        ))}
      </div>
      <div class="rules-block">
        <div>
          <h3>{content.rules.title}</h3>
          <ul>
            {content.rules.items.map(item => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section section-alt" id="about">
    <div class="container about-grid">
      <div>
        <h2 class="section-title section-title-left">{content.about.title}</h2>
        <div class="about-text">
          {content.about.paragraphs.map(p => (
            <p set:html={p.replace('АОЦ Севрюкова', '<strong>АОЦ Севрюкова</strong>')} />
          ))}
        </div>
        <div class="about-features">
          {content.about.features.map(feature => (
            <div class="feature-item">
              {feature.title}
              <span>{feature.subtitle}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="about-image"></div>
    </div>
  </section>

  <!-- Doctors -->
  <section class="section" id="doctors">
    <div class="container">
      <h2 class="section-title">Наша команда</h2>
      <p class="section-subtitle">Остеопаты, невролог, травматолог-ортопед, психолог</p>
      <div class="doctors-grid">
        {content.doctors.map(doctor => (
          <div class="doctor-card">
            <div class="doctor-photo">{doctor.icon}</div>
            <div class="doctor-name">{doctor.name}</div>
            <div class="doctor-spec">{doctor.specialty}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="section section-alt" id="reviews">
    <div class="container">
      <h2 class="section-title">Отзывы пациентов</h2>
      <p class="section-subtitle">{content.reviews.subtitle}</p>
      <div class="reviews-grid">
        {content.reviews.items.map(review => (
          <div class="review-card">
            <div class="review-text">«{review.text}»</div>
            <div class="review-author">— {review.author}</div>
          </div>
        ))}
      </div>
      <div class="aggregators-row">
        {content.aggregators.map(agg => (
          <a href={agg.url} target="_blank" rel="noopener noreferrer" class="aggregator-link">{agg.name}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Documents -->
  <section class="section section-alt" id="documents">
    <div class="container">
      <h2 class="section-title">{content.documents.title}</h2>
      <p class="section-subtitle">{content.documents.description}</p>
      <div class="documents-wrap">
        <div class="documents-carousel">
          {docsInfo.map(doc => (
            <button
              type="button"
              class="doc-card"
              onclick={`openLightbox('${doc.pdf}', '${doc.name.replace(/'/g, "\\'")}')`}
            >
              <div class="doc-preview pdf-preview-container" data-pdf={doc.pdf}>
                <div class="pdf-loading" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:var(--text-muted);">
                  <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                </div>
                <canvas class="pdf-canvas"></canvas>
              </div>
              <div class="doc-name">{doc.name}</div>
            </button>
          ))}
        </div>
        <div class="documents-fade-left"></div>
        <div class="documents-fade-right"></div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section" id="contact">
    <div class="container">
      <div class="form-section">
        <div class="form-grid">
          <div>
            <h3 class="form-title">Запишитесь на консультацию</h3>
            <p class="contact-info-text">Мы подберём удобное время и специалиста.</p>
            <p class="contact-detail">📍 {content.contacts.address}</p>
            <p class="contact-detail">📞 <a href={`tel:${content.contacts.phoneTel}`}>{content.contacts.phone}</a></p>
          </div>
          <div>
            <form id="booking-form" class="form-fields">
              <div class="hidden" aria-hidden="true">
                <label>Не заполняйте <input type="text" name="bot_field" id="bot_field" tabindex="-1" autocomplete="off" /></label>
              </div>
              <div class="form-row">
                <input type="text" id="name" name="name" placeholder="Ваше имя" required />
              </div>
              <div class="form-row">
                <input type="tel" id="phone" name="phone" placeholder="+7 (___) ___-__-__" required />
              </div>
              <div class="form-row">
                <select id="service" name="service">
                  {content.services.map((service, i) => (
                    <option value={service.name} selected={service.featured}>{service.name}</option>
                  ))}
                  <option value="Другое">Другое / Затрудняюсь ответить</option>
                </select>
              </div>
              <div class="form-submit-row">
                <button type="submit">Отправить заявку</button>
              </div>
              <p class="form-note">Мы перезвоним</p>
              <p class="form-privacy">
                Нажимая на кнопку, вы даёте согласие на обработку персональных данных и соглашаетесь с
                <button type="button" onclick="toggleModal()">Политикой конфиденциальности</button>.
              </p>
            </form>
            <div id="form-success" class="form-success" style="display:none;">
              <div class="form-success-icon">✓</div>
              <h3 class="form-title">Спасибо!</h3>
              <p class="contact-info-text">Ваша заявка успешно отправлена. Мы свяжемся с вами в ближайшее время.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <h4 class="footer-logo">✦ {content.clinic.name}</h4>
        <p style="max-width:300px;">{content.clinic.tagline}</p>
      </div>
      <div>
        <h4>Время работы</h4>
        <p>{content.clinic.hours}</p>
        <p style="margin-top:10px;">{content.clinic.hoursNote}</p>
      </div>
      <div>
        <h4>Полезное</h4>
        {content.footer.links.map(link => (
          link.modal ? (
            <button type="button" onclick="toggleModal()" style="background:none;border:none;color:#bcccd6;cursor:pointer;padding:0;font-size:inherit;text-align:left;display:block;margin-bottom:8px;">{link.label}</button>
          ) : (
            <a href={link.href}>{link.label}</a>
          )
        ))}
      </div>
    </div>
    <div class="container footer-bottom">
      © {new Date().getFullYear()} «{content.clinic.name}».
      <p class="footer-disclaimer">
        Обращаем ваше внимание на то, что данный интернет-сайт носит исключительно информационный характер и ни при каких условиях не является публичной офертой, определяемой положениями Статьи 437 (2) Гражданского кодекса Российской Федерации.
        Имеются противопоказания. Необходима консультация специалиста.
      </p>
    </div>
  </footer>

  <!-- Privacy Modal -->
  <div id="privacy-modal" class="modal-overlay">
    <div class="modal-backdrop" onclick="toggleModal()"></div>
    <div class="modal-content-wrap">
      <div class="modal-panel">
        <div class="modal-header">
          <h3>Политика конфиденциальности</h3>
          <button class="modal-close" onclick="toggleModal()" aria-label="Закрыть">
            <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
        <div class="modal-body">
          <p>Настоящая Политика конфиденциальности описывает, как мы собираем, используем и защищаем ваши персональные данные в соответствии с Федеральным законом № 152-ФЗ «О персональных данных».</p>
          <h4>1. Сбор данных</h4>
          <p>Мы собираем только те данные, которые вы добровольно предоставляете при заполнении формы записи на сайте: имя и номер телефона.</p>
          <h4>2. Использование данных</h4>
          <p>Предоставленные данные используются исключительно для обратной связи с вами, уточнения деталей записи на прием и оказания медицинских услуг.</p>
          <h4>3. Защита данных</h4>
          <p>Мы принимаем все необходимые организационные и технические меры для защиты персональных данных от неправомерного доступа, уничтожения, изменения или блокирования.</p>
          <h4>4. Передача третьим лицам</h4>
          <p>Ваши персональные данные не передаются третьим лицам, за исключением случаев, прямо предусмотренных законодательством РФ.</p>
        </div>
        <div class="modal-footer">
          <button onclick="toggleModal()">Понятно</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lightbox-modal" class="lightbox-overlay">
    <div class="lightbox-backdrop" onclick="closeLightbox()"></div>
    <div class="lightbox-inner">
      <button class="lightbox-close" onclick="closeLightbox()" aria-label="Закрыть">
        <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      <div class="lightbox-canvas-wrap">
        <div id="lightbox-loading" class="lightbox-loading">
          <svg width="40" height="40" fill="none" stroke="var(--primary-mid)" viewBox="0 0 24 24" style="animation:spin 1s linear infinite;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
        </div>
        <canvas id="lightbox-canvas" style="max-width:100%;max-height:85vh;"></canvas>
      </div>
      <h3 id="lightbox-title" class="lightbox-title"></h3>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>

  <script>
    window.pdfjsLib = window['pdfjs-dist/build/pdf'];
    pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

    const lightboxModal = document.getElementById('lightbox-modal');
    const lightboxCanvas = document.getElementById('lightbox-canvas') as HTMLCanvasElement;
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxLoading = document.getElementById('lightbox-loading');

    window.openLightbox = async function(pdfUrl: string, title: string) {
      if (!lightboxModal) return;
      lightboxModal.classList.add('open');
      document.body.style.overflow = 'hidden';
      if (lightboxTitle) lightboxTitle.textContent = title;
      if (lightboxLoading) lightboxLoading.style.display = 'flex';

      const ctx = lightboxCanvas.getContext('2d');
      if (ctx) ctx.clearRect(0, 0, lightboxCanvas.width, lightboxCanvas.height);

      try {
        const pdf = await pdfjsLib.getDocument(pdfUrl).promise;
        const page = await pdf.getPage(1);
        const viewport = page.getViewport({ scale: 2.5 });
        lightboxCanvas.width = viewport.width;
        lightboxCanvas.height = viewport.height;
        await page.render({ canvasContext: ctx!, viewport }).promise;
      } catch (err) {
        console.error('Error rendering PDF:', err);
      } finally {
        if (lightboxLoading) lightboxLoading.style.display = 'none';
      }
    };

    window.closeLightbox = function() {
      if (lightboxModal) {
        lightboxModal.classList.remove('open');
        document.body.style.overflow = '';
      }
    };

    document.addEventListener('DOMContentLoaded', () => {
      const pdfContainers = document.querySelectorAll('.pdf-preview-container');

      const renderThumbnail = async (container: Element) => {
        const el = container as HTMLElement;
        if (el.dataset.rendered === 'true') return;
        el.dataset.rendered = 'true';

        const pdfUrl = el.dataset.pdf;
        const canvas = el.querySelector('.pdf-canvas') as HTMLCanvasElement;
        const loading = el.querySelector('.pdf-loading') as HTMLElement;
        if (!canvas || !pdfUrl) return;

        try {
          const pdf = await pdfjsLib.getDocument(pdfUrl).promise;
          const page = await pdf.getPage(1);
          const viewport = page.getViewport({ scale: 1.0 });
          canvas.width = viewport.width;
          canvas.height = viewport.height;
          const ctx = canvas.getContext('2d');
          await page.render({ canvasContext: ctx!, viewport }).promise;
          canvas.classList.add('loaded');
          if (loading) loading.style.display = 'none';
        } catch (err) {
          console.error('Error rendering thumbnail:', pdfUrl, err);
        }
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            renderThumbnail(entry.target);
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: '200px' });

      pdfContainers.forEach(container => observer.observe(container));
    });

    window.toggleModal = function() {
      const modal = document.getElementById('privacy-modal');
      if (modal) {
        const isOpen = modal.classList.contains('open');
        modal.classList.toggle('open', !isOpen);
        document.body.style.overflow = isOpen ? '' : 'hidden';
      }
    };

    const speedDialBtn = document.getElementById('speed-dial-btn');
    const speedDialItems = document.querySelectorAll('.speed-dial-item');
    const iconDefault = document.getElementById('speed-dial-icon-default');
    const iconClose = document.getElementById('speed-dial-icon-close');
    let isSpeedDialOpen = false;

    if (speedDialBtn) {
      speedDialBtn.addEventListener('click', () => {
        isSpeedDialOpen = !isSpeedDialOpen;

        if (isSpeedDialOpen) {
          iconDefault?.classList.add('hidden-icon');
          iconClose?.classList.remove('hidden-icon');
          speedDialItems.forEach(item => item.classList.add('open'));
        } else {
          iconDefault?.classList.remove('hidden-icon');
          iconClose?.classList.add('hidden-icon');
          speedDialItems.forEach(item => item.classList.remove('open'));
        }
      });
    }

    const phoneInput = document.getElementById('phone') as HTMLInputElement;
    if (phoneInput) {
      phoneInput.addEventListener('input', function (e) {
        const target = e.target as HTMLInputElement;
        const x = target.value.replace(/\D/g, '').match(/(\d{0,1})(\d{0,3})(\d{0,3})(\d{0,2})(\d{0,2})/);
        if (!x || !x[2]) { target.value = '+7'; return; }
        target.value = '+7 (' + x[2] + (x[3] ? ') ' + x[3] : '') + (x[4] ? '-' + x[4] : '') + (x[5] ? '-' + x[5] : '');
      });
    }

    const form = document.getElementById('booking-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const botField = (document.getElementById('bot_field') as HTMLInputElement)?.value;
        if (botField) {
          form.style.display = 'none';
          if (successMsg) successMsg.style.display = 'block';
          return;
        }

        const API_URL = '/api/submit';

        try {
          form.style.display = 'none';
          if (successMsg) successMsg.style.display = 'block';
        } catch (error) {
          console.error(error);
          alert('Произошла ошибка при отправке заявки. Пожалуйста, напишите в WhatsApp.');
        }
      });
    }
  </script>
</Layout>
