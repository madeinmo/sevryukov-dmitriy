---
import Layout from '../layouts/Layout.astro';
import content from '../data/content.json';
import docsInfo from '../data/documents.json';
---

<Layout 
  title="Остеопат Севрюков Дмитрий Игоревич | Астрахань"
  description="Врач-остеопат и невролог в Астрахани. Лечение причин боли, а не симптомов. Прием детей и взрослых."
>
  <!-- Speed Dial Menu (Floating Action) -->
  <div id="speed-dial-container" class="fixed bottom-6 right-6 z-50 flex flex-col-reverse items-center gap-3">
    <!-- Main FAB -->
    <button id="speed-dial-btn" aria-label="Связаться" class="relative w-14 h-14 bg-brand-blue text-white rounded-full shadow-xl hover:bg-blue-800 transition-all flex items-center justify-center z-10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue">
      <svg id="speed-dial-icon-default" class="w-7 h-7 absolute transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
      <svg id="speed-dial-icon-close" class="w-7 h-7 absolute transition-all duration-300 scale-0 opacity-0 rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    
    <!-- WhatsApp -->
    <a href={content.contacts.whatsapp} target="_blank" rel="noopener noreferrer" class="speed-dial-item absolute bottom-0 w-12 h-12 bg-green-500 text-white rounded-full shadow-md hover:bg-green-600 flex items-center justify-center transition-all duration-300 opacity-0 scale-50 pointer-events-none" aria-label="WhatsApp">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20.52 3.449A11.94 11.94 0 0 0 12 0a11.96 11.96 0 0 0-11.95 12c0 1.91.5 3.78 1.45 5.43L0 24l6.72-1.75a11.95 11.95 0 0 0 5.28 1.23h.01a11.95 11.95 0 0 0 11.96-12 11.9 11.9 0 0 0-3.45-8.03ZM12 21.48a9.9 9.9 0 0 1-5.06-1.37l-.36-.21-3.76.99 1-3.66-.23-.37A9.94 9.94 0 0 1 2.05 12a9.96 9.96 0 0 1 9.95-10 9.9 9.9 0 0 1 7.04 2.92A9.9 9.9 0 0 1 21.95 12a9.95 9.95 0 0 1-9.95 9.48Zm5.46-7.44c-.3-.15-1.78-.88-2.05-.98-.28-.1-.48-.15-.68.15-.2.3-.77.98-.95 1.18-.17.2-.35.23-.65.08-.3-.15-1.27-.47-2.42-1.32-.89-.66-1.5-1.48-1.67-1.78-.18-.3 0-.46.15-.61.13-.14.3-.35.45-.53.15-.18.2-.3.3-.5.1-.2.05-.38-.03-.53-.08-.15-.68-1.64-.93-2.25-.24-.6-.48-.52-.68-.53-.18-.01-.38-.01-.58-.01-.2 0-.53.08-.8.38-.28.3-1.05 1.03-1.05 2.5 0 1.48 1.08 2.9 1.23 3.1.15.2 2.12 3.23 5.14 4.53.72.3 1.28.48 1.72.62.72.23 1.38.2 1.9.12.58-.09 1.78-.73 2.03-1.43.25-.7.25-1.3.18-1.43-.08-.13-.28-.2-.58-.35Z"/></svg>
    </a>
    
    <!-- Telegram -->
    <a href={content.contacts.telegram} target="_blank" rel="noopener noreferrer" class="speed-dial-item absolute bottom-0 w-12 h-12 bg-blue-500 text-white rounded-full shadow-md hover:bg-blue-600 flex items-center justify-center transition-all duration-300 opacity-0 scale-50 pointer-events-none" aria-label="Telegram" style="transition-delay: 50ms;">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.123-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    </a>
    
    <!-- Max -->
    <a href={content.contacts.max} target="_blank" rel="noopener noreferrer" class="speed-dial-item absolute bottom-0 w-12 h-12 bg-white rounded-full shadow-md hover:scale-110 flex items-center justify-center transition-all duration-300 opacity-0 scale-50 pointer-events-none" aria-label="Max" style="transition-delay: 100ms;">
      <img src="https://maxicons.ru/icons/MAX.svg" alt="Иконка MAX" width="32" height="32" />
    </a>
  </div>

  <!-- Header (Glassmorphism) -->
  <header class="fixed top-0 w-full z-40 bg-white/80 backdrop-blur-md border-b border-slate-200/50 shadow-sm transition-all duration-300">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-20">
        <div class="flex-shrink-0 flex items-center">
          <span class="font-bold text-xl sm:text-2xl text-brand-blue tracking-tight">Севрюков Д.И.</span>
        </div>
        <nav class="hidden md:flex space-x-6 lg:space-x-8">
          <a href="#about" class="text-slate-600 hover:text-brand-blue font-medium transition-colors">Обо мне</a>
          <a href="#services" class="text-slate-600 hover:text-brand-blue font-medium transition-colors">Услуги</a>
          <a href="#documents" class="text-slate-600 hover:text-brand-blue font-medium transition-colors">Документы</a>
          <a href="#contacts" class="text-slate-600 hover:text-brand-blue font-medium transition-colors">Контакты</a>
        </nav>
        <div class="flex items-center gap-4">
          <a href="tel:+79064327871" class="text-brand-blue font-bold text-lg hidden lg:block hover:text-blue-800 transition-colors">+7 906 432-78-71</a>
          <a href="#contacts" class="inline-flex justify-center items-center px-5 py-2.5 border border-transparent text-sm font-bold rounded-lg text-white bg-brand-gold hover:bg-yellow-500 shadow-sm transition-all hover:-translate-y-0.5 whitespace-nowrap">
            Записаться
          </a>
        </div>
      </div>
    </div>
  </header>

  <main class="pt-20">
    <!-- Hero Section (Двухколоночный) -->
    <section class="relative bg-gradient-to-br from-brand-sand via-white to-blue-50 py-16 sm:py-24 lg:py-32 overflow-hidden">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="max-w-2xl order-2 lg:order-1 text-center lg:text-left flex flex-col items-center lg:items-start">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 tracking-tight mb-6 leading-tight">
              {content.hero.title}
            </h1>
            <p class="text-xl sm:text-2xl text-brand-blue font-semibold mb-6">
              {content.hero.subtitle}
            </p>
            <p class="text-lg sm:text-xl text-slate-600 mb-8 leading-relaxed">
              {content.hero.description}
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 mb-10 w-full sm:w-auto">
              <a href="#contacts" class="inline-flex justify-center items-center px-8 py-4 border border-transparent text-lg font-bold rounded-xl text-white bg-brand-blue hover:bg-blue-800 shadow-lg hover:shadow-xl transition-all hover:-translate-y-0.5 w-full sm:w-auto">
                {content.hero.cta}
              </a>
              <a href="#services" class="inline-flex justify-center items-center px-8 py-4 border-2 border-slate-200 text-lg font-bold rounded-xl text-slate-700 bg-white hover:bg-slate-50 hover:border-slate-300 transition-all w-full sm:w-auto">
                Смотреть цены
              </a>
            </div>

            <div class="flex flex-wrap justify-center lg:justify-start gap-3">
              {content.hero.badges.map(badge => (
                <span class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-white text-brand-blue shadow-sm border border-slate-100">
                  <svg class="w-4 h-4 mr-2 text-brand-gold" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                  {badge}
                </span>
              ))}
            </div>
          </div>
          
          <div class="relative flex justify-center lg:justify-end order-1 lg:order-2 mb-4 lg:mb-0">
            <div class="w-72 h-72 sm:w-96 sm:h-96 lg:w-[400px] lg:h-[500px] overflow-hidden rounded-3xl">
              <img 
                src="/images/portrait.jpg" 
                alt="Севрюков Дмитрий Игоревич" 
                loading="eager"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section (Timeline & Quote) -->
    <section id="about" class="py-20 sm:py-32 bg-white relative">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-16 text-center">{content.about.title}</h2>
        
        <div class="relative mb-20">
          <svg class="absolute top-0 left-0 transform -translate-x-6 -translate-y-8 h-24 w-24 text-brand-sand" fill="currentColor" viewBox="0 0 32 32" aria-hidden="true"><path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.896 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z"/></svg>
          <p class="relative text-2xl sm:text-3xl font-medium text-slate-700 leading-relaxed italic z-10">
            {content.about.quote}
          </p>
        </div>

        <div class="space-y-12 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-slate-200 before:to-transparent">
          {content.about.timeline.map((item, index) => (
            <div class={`relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active`}>
              <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white bg-brand-blue text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              </div>
              <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-shadow">
                <div class="flex items-center justify-between mb-2">
                  <span class="font-bold text-brand-gold text-lg">{item.year}</span>
                </div>
                <h3 class="font-bold text-slate-900 text-xl mb-2">{item.title}</h3>
                <p class="text-slate-600 leading-relaxed">{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-20 sm:py-32 bg-slate-50 relative">
      <div class="absolute inset-0 bg-[url('/pattern.svg')] opacity-5"></div>
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-16 text-center">Услуги и цены</h2>
        
        <div class="grid gap-8 md:grid-cols-2">
          {content.services.map((service, index) => (
            <div class={`bg-white rounded-3xl p-8 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 relative overflow-hidden group ${index === 1 ? 'border-2 border-brand-gold shadow-lg' : 'border border-slate-100 shadow-sm'}`}>
              {index === 1 && <div class="absolute top-0 right-0 bg-brand-gold text-white text-xs font-bold px-3 py-1 rounded-bl-lg">Частый выбор</div>}
              
              <h3 class="text-2xl font-bold text-brand-blue mb-2">{service.name}</h3>
              {service.audience && <p class="text-sm font-medium text-slate-500 mb-6 bg-slate-100 inline-block px-3 py-1 rounded-full">{service.audience}</p>}
              
              <div class="flex flex-col mb-8 mt-auto">
                <div class="flex items-end gap-2">
                  <span class="text-4xl font-extrabold text-slate-900">{service.price}</span>
                </div>
                {service.duration && <span class="text-slate-500 font-medium mt-1">Длительность: {service.duration}</span>}
              </div>

              <button 
                onclick={`document.getElementById('service').value = '${service.name}'; document.getElementById('contacts').scrollIntoView({behavior: 'smooth'});`}
                class={`w-full py-4 rounded-xl font-bold text-lg transition-colors ${index === 1 ? 'bg-brand-gold hover:bg-yellow-500 text-slate-900' : 'bg-slate-100 hover:bg-brand-blue hover:text-white text-slate-900'}`}
              >
                Записаться
              </button>
            </div>
          ))}
        </div>
        
        <div class="mt-16 bg-white rounded-3xl p-8 sm:p-10 border border-slate-100 shadow-sm flex flex-col md:flex-row gap-8 items-center justify-between">
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-slate-900 mb-4">{content.rules.title}</h3>
            <ul class="space-y-4">
              {content.rules.items.map((item) => (
                <li class="flex items-start">
                  <div class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-50 flex items-center justify-center mt-0.5">
                    <svg class="h-4 w-4 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  </div>
                  <span class="ml-3 text-slate-700 text-lg">{item}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="flex-shrink-0 p-6 bg-brand-sand rounded-2xl">
             <svg class="w-16 h-16 text-brand-gold opacity-50" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact Form Section -->
    <section id="contacts" class="py-20 sm:py-32 bg-brand-blue text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-900 to-brand-blue"></div>
      <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-blue-800 blur-3xl opacity-50"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 rounded-full bg-brand-gold blur-3xl opacity-20"></div>
      
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          
          <div class="bg-white rounded-[2rem] p-8 sm:p-12 text-slate-900 shadow-2xl relative order-2 lg:order-1">
            <form id="booking-form" class="space-y-6 relative z-10">
              <!-- Honeypot -->
              <div class="hidden">
                <label>Не заполняйте это поле <input type="text" name="bot_field" id="bot_field" tabindex="-1" autocomplete="off" /></label>
              </div>
              
              <div>
                <label for="name" class="block text-sm font-bold text-slate-700 mb-2">Ваше имя</label>
                <input type="text" id="name" name="name" required class="w-full px-5 py-4 rounded-xl bg-slate-50 border-2 border-transparent focus:ring-4 focus:ring-brand-blue/20 focus:border-brand-blue outline-none transition-all text-lg" placeholder="Иван Иванов">
              </div>
              
              <div>
                <label for="phone" class="block text-sm font-bold text-slate-700 mb-2">Телефон</label>
                <input type="tel" id="phone" name="phone" required class="w-full px-5 py-4 rounded-xl bg-slate-50 border-2 border-transparent focus:ring-4 focus:ring-brand-blue/20 focus:border-brand-blue outline-none transition-all text-lg" placeholder="+7 (999) 000-00-00">
              </div>

              <div>
                <label for="service" class="block text-sm font-bold text-slate-700 mb-2">Желаемая услуга</label>
                <div class="relative">
                  <select id="service" name="service" class="w-full px-5 py-4 rounded-xl bg-slate-50 border-2 border-transparent focus:ring-4 focus:ring-brand-blue/20 focus:border-brand-blue outline-none transition-all text-lg appearance-none cursor-pointer">
                    <option value="Остеопатия детский сеанс">Остеопатия детский сеанс</option>
                    <option value="Остеопатия взрослый сеанс" selected>Остеопатия взрослый сеанс</option>
                    <option value="Консультация">Консультация</option>
                    <option value="Другое">Другое / Затрудняюсь ответить</option>
                  </select>
                  <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-5 text-slate-500">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                  </div>
                </div>
              </div>
              
              <button type="submit" class="w-full bg-brand-gold hover:bg-yellow-500 text-slate-900 font-extrabold text-xl py-5 px-8 rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1 mt-4">
                Отправить заявку
              </button>
              
              <p class="text-sm text-slate-500 text-center mt-6 leading-relaxed">
                Нажимая на кнопку, вы даете согласие на обработку персональных данных и соглашаетесь с <button type="button" class="underline hover:text-brand-blue font-semibold" onclick="toggleModal()">Политикой конфиденциальности</button>.
              </p>
            </form>
            
            <div id="form-success" class="hidden text-center py-12 relative z-10">
              <div class="w-24 h-24 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-12 h-12 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
              </div>
              <h3 class="text-3xl font-extrabold text-slate-900 mb-4">Спасибо!</h3>
              <p class="text-slate-600 text-lg">Ваша заявка успешно отправлена. Я свяжусь с вами в ближайшее время.</p>
            </div>
          </div>

          <div class="order-1 lg:order-2">
            <h2 class="text-4xl sm:text-5xl font-extrabold mb-6">Записаться на прием</h2>
            <p class="text-blue-100 mb-12 text-xl leading-relaxed">Оставьте свои данные, и я свяжусь с вами в ближайшее время для уточнения деталей и выбора удобного времени сеанса.</p>
            
            <div class="space-y-8 bg-blue-900/40 p-8 rounded-3xl backdrop-blur-sm border border-white/10">
              <div class="flex items-start">
                <div class="bg-white/10 p-3 rounded-full shrink-0 mr-4">
                  <svg class="w-6 h-6 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <div>
                  <h4 class="text-white/60 text-sm font-medium mb-1">Адрес кабинета</h4>
                  <span class="text-lg font-medium">{content.contacts.address}</span>
                </div>
              </div>
              <div class="flex items-start">
                <div class="bg-white/10 p-3 rounded-full shrink-0 mr-4">
                  <svg class="w-6 h-6 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                </div>
                <div>
                  <h4 class="text-white/60 text-sm font-medium mb-1">Телефон</h4>
                  <a href="tel:+79064327871" class="text-lg font-medium hover:text-brand-gold transition-colors">{content.contacts.phone}</a>
                </div>
              </div>
            </div>
          </div>
          
        </div>
      </div>
    </section>

    <!-- Documents & Aggregators Section -->
    <section id="documents" class="py-20 sm:py-32 bg-slate-50 relative overflow-hidden">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6 text-center">Документы и Сертификаты</h2>
